client_secrets.json
token.json
credentials.json
google_api_key.txt
*.pem
*.key
*.p12
*.pfx
id_rsa*
# Environment files (the *.example templates are kept; real ones ignored)
.env
.env.*
!.env.example

# ═══════════════ CLIENT DATA — confidential, never publish ═══════════════
# Generated reports (real client domains, GSC metrics, page content)
relatorios/
relatorios-analise/
historico.json
historico_posicao.json
# Client deliverables / exports
*.docx
*.xlsx
# Live-crawl URL lists (real client URLs)
*_urls.txt
!*.example.txt

