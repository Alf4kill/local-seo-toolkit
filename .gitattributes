# Normalize line endings: store LF in the repo, check out native on each OS.
* text=auto

# Keep Windows-native scripts as CRLF on checkout
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts must stay LF even on Windows
*.sh text eol=lf

# Treat these as binary (no line-ending or diff munging)
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.npy binary
